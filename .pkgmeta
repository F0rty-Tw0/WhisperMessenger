package-as: WhisperMessenger
enable-toc-creation: yes

ignore:
  - .github
  - .claude
  - .omc
  - .wolf
  - tests
  - scripts
  - docs
  - dist
  - plans
  - .editorconfig
  - .gitignore
  - .luacheckrc
  - stylua.toml
  - CLAUDE.md
  - README.md
  - LICENSE

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
